# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars-fill in your values, do NOT commit to git
# Add this file to .gitignore
# ─────────────────────────────────────────────────────────────────────────────

aws_region    = "ap-south-1"
project_name  = "ganesh-devops"
instance_type = "t3.large"
key_pair_name = "your-keypair-name"       # replace with your actual key pair
allowed_cidr  = "YOUR.IP.ADDRESS/32"      # replace with your public IP
vpc_cidr      = "10.0.0.0/16"
